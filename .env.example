# Porta interna do container da app
PORT=8080

# NGINX
NGINX_PORT=8000

# PostgreSQL
POSTGRES_USER=capital-pipefy
POSTGRES_PASSWORD=capital-pipefy
POSTGRES_DB=capital-pipefy
DATABASE_URL=postgres://capital-pipefy:capital-pipefy@postgres:5432/capital-pipefy?sslmode=disable

# Redis
REDIS_URL=redis:6379

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Pipefy (simulado)
PIPEFY_PIPE_ID=your_pipe_id_here
PIPEFY_API_URL=https://api.pipefy.com/graphql
PIPEFY_TOKEN=your_token_here

# Pipefy resilience (optional — defaults shown)
PIPEFY_HTTP_TIMEOUT=10s
PIPEFY_MAX_RETRIES=3
PIPEFY_RETRY_DELAY=500ms
PIPEFY_CB_THRESHOLD=5
PIPEFY_CB_OPEN_TIMEOUT=30s
