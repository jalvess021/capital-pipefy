# Porta interna do container da app
PORT=8080

# NGINX
NGINX_PORT=8000

# Grafana
GRAFANA_PORT=3000

# PostgreSQL
POSTGRES_USER=capital-pipefy
POSTGRES_PASSWORD=capital-pipefy
POSTGRES_DB=capital-pipefy
DATABASE_URL=postgres://capital-pipefy:capital-pipefy@postgres:5432/capital-pipefy?sslmode=disable

# [Rate limiting - INFRA LAYER] (padrao: 10/20) (teste de carga K6: 10000/5000)
NGINX_RATE_LIMIT_RPS=10
NGINX_RATE_LIMIT_BURST=20

# [Rate limiting - APP LAYER] (padrao: 10/true) (teste de carga K6: 10/false)
RATE_LIMIT_RPS=10
# False para load-test (k6 usa 1 IP, distorceria resultado)
RATE_LIMIT_ENABLED=true

# Redis (Para rate limiting)
REDIS_URL=redis://redis:6379

# Database connection pool
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Pipefy (simulado)
PIPEFY_PIPE_ID=your_pipe_id_here
PIPEFY_API_URL=https://api.pipefy.com/graphql
PIPEFY_TOKEN=your_token_here

# Pipefy resiliencia (Opcional com fallback padrao abaixo)
PIPEFY_HTTP_TIMEOUT=10s
PIPEFY_MAX_RETRIES=3
PIPEFY_RETRY_DELAY=500ms
PIPEFY_CB_THRESHOLD=5
PIPEFY_CB_OPEN_TIMEOUT=30s
